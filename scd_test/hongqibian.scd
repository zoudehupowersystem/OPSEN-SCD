			<ConfReportControl max="12"/>
			<GetCBValues/>
			<ReportSettings cbName="Conf" datSet="Dyn" rptID="Dyn" optFields="Dyn" trgOps="Dyn" intgPd="Dyn"/>
			<FileHandling/>
			<ConfLNs fixPrefix="true" fixLnInst="true"/>
		</Services>
		<AccessPoint name="S1">
			<Server>
				<Authentication/>
				<LDevice inst="LD0">
					<LN0 lnClass="LLN0" lnType="JX1_GDNR_LLN0_3_612RA" inst="">
