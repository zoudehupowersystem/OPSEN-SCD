							<FCDA ldInst="LD0" prefix="Fn3I0" lnClass="GGIO" lnInst="1" doName="VRtgSnd" daName="setMag.f" fc="SP"/>
							<FCDA ldInst="LD0" prefix="SYNPH" lnClass="GGIO" lnInst="1" doName="VRtgSnd" daName="setMag.f" fc="SP"/>
							<FCDA ldInst="LD0" prefix="CT" lnClass="GGIO" lnInst="2" doName="VRtgSnd" daName="setMag.f" fc="SP"/>
							<FCDA ldInst="LD0" lnClass="LLN0" doName="ARtg" daName="setMag.f" fc="SP"/>
